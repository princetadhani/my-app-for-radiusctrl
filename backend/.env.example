# ========================================
# FreeRADIUS Control Backend Configuration
# ========================================
# Copy this file to .env and configure for your environment
# Command: cp .env.example .env

# ----------------------------------------
# Server Configuration
# ----------------------------------------
# Port where the backend API server will run
PORT=3001

# Node environment (development, production, test)
NODE_ENV=development

# ----------------------------------------
# FreeRADIUS Paths
# ----------------------------------------
# Base directory for FreeRADIUS configuration files
# This is where all config files (users, clients.conf, radiusd.conf, etc.) are located
FREERADIUS_BASE_DIR=/etc/freeradius/3.0

# FreeRADIUS log file path
# Used for live log streaming in the UI
FREERADIUS_LOG_FILE=/var/log/freeradius/radius.log

# COA (Change of Authorization) files directory
# This is where COA command files created by users will be saved
# Files are created here and used by radclient for COA/Disconnect commands
FREERADIUS_COA_DIR=/etc/freeradius/3.0/coa

# FreeRADIUS systemd service name
# Used for service control commands (start, stop, reload, restart, status)
FREERADIUS_SERVICE_NAME=freeradius

# ----------------------------------------
# WebSocket Configuration
# ----------------------------------------
# Frontend URL allowed to connect to WebSocket
# Update this if your frontend runs on a different host/port
# For production, set this to your actual frontend URL
# Examples:
#   - Local development: http://localhost:3000
#   - Remote server: http://10.76.191.233:3000
#   - Multiple origins: Not supported in this variable (CORS allows all origins by default)
WEBSOCKET_CORS_ORIGIN=http://localhost:3000

# ----------------------------------------
# Notes
# ----------------------------------------
# 1. After creating .env, ensure the COA directory exists:
#    sudo mkdir -p /etc/freeradius/3.0/coa
#    sudo chown -R $USER:freerad /etc/freeradius/3.0/coa
#    sudo chmod -R 775 /etc/freeradius/3.0/coa
#
# 2. Configure sudo permissions for FreeRADIUS service control:
#    sudo visudo
#    Add: your-username ALL=(ALL) NOPASSWD: /bin/systemctl reload freeradius
#    Add: your-username ALL=(ALL) NOPASSWD: /bin/systemctl restart freeradius
#    Add: your-username ALL=(ALL) NOPASSWD: /bin/systemctl status freeradius
#    Add: your-username ALL=(ALL) NOPASSWD: /bin/systemctl show freeradius
#
# 3. Ensure FreeRADIUS log file is readable:
#    sudo chmod 644 /var/log/freeradius/radius.log
